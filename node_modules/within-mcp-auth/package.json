  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "oauth",
    "within",
    "sdk",
    "auth"
  ],
  "license": "MIT",
  "homepage": "https://getwith.in",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiwanaca/within-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/tiwanaca/within-sdk/issues"
  },
  "scripts": {
    "build": "npx tsc",
    "prepublishOnly": "npm run build",
    "test": "npx tsx --test src/*.test.ts"
  },
  "dependencies": {
    "jose": "^6.0.11"
  },
  "peerDependencies": {
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "tsx": "^4.21.0",
